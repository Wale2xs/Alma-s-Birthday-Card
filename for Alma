<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Happy Birthday, AlmaAliyah</title>

<!-- ═══════════════════════════════════════════════════════════
     ✏️  EDIT ME — scroll down to the CONFIG script at the very
     bottom of this file to change her name, your message,
     and the photo captions. Photos can be added just by
     clicking the frames when the page is open.
     ═══════════════════════════════════════════════════════════ -->

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">

<style>
:root{
  --wine:#2B0F1E;          /* deep evening wine  */
  --wine-soft:#3D1830;
  --blush:#E9B8C4;         /* rose blush         */
  --champagne:#D9B98A;     /* candlelight gold   */
  --ivory:#F7EFE9;
  --shadow:rgba(0,0,0,.35);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  background:radial-gradient(120% 90% at 50% 0%, var(--wine-soft) 0%, var(--wine) 60%);
  color:var(--ivory);
  font-family:'Jost',sans-serif;
  font-weight:300;
  overflow-x:hidden;
  min-height:100vh;
}
::selection{background:var(--blush);color:var(--wine)}

/* ── falling petals ─────────────────────────── */
.petal{
  position:fixed;top:-4vh;pointer-events:none;z-index:1;
  font-size:14px;color:var(--blush);opacity:.55;
  animation:fall linear infinite;
}
@keyframes fall{
  to{transform:translateY(110vh) rotate(360deg);opacity:0}
}
@media (prefers-reduced-motion:reduce){
  .petal{display:none}
  *{animation-duration:.01s!important;transition-duration:.01s!important}
}

/* ── hero ───────────────────────────────────── */
.hero{
  min-height:100vh;display:flex;flex-direction:column;
  align-items:center;justify-content:center;text-align:center;
  padding:2rem;position:relative;z-index:2;
}
.hero .eyebrow{
  letter-spacing:.45em;text-transform:uppercase;font-size:.72rem;
  color:var(--champagne);margin-bottom:1.8rem;
  opacity:0;animation:rise 1.2s .3s ease forwards;
}
.hero h1{
  font-family:'Cormorant Garamond',serif;font-weight:500;font-style:italic;
  font-size:clamp(3rem,10vw,6.5rem);line-height:1.05;
  opacity:0;animation:rise 1.2s .7s ease forwards;
}
.hero h1 .name{
  display:block;font-style:normal;color:var(--blush);
  font-size:clamp(3.4rem,11vw,7.5rem);margin-top:.1em;
}
.hero p{
  margin-top:2rem;font-size:1rem;letter-spacing:.06em;color:rgba(247,239,233,.75);
  max-width:34ch;opacity:0;animation:rise 1.2s 1.1s ease forwards;
}
.candle{
  margin-top:3rem;opacity:0;animation:rise 1.2s 1.5s ease forwards;
}
.flame{
  width:14px;height:22px;margin:0 auto 4px;
  background:radial-gradient(circle at 50% 80%, #FFD9A0 0%, #F2A65A 55%, transparent 75%);
  border-radius:50% 50% 50% 50%/60% 60% 40% 40%;
  filter:blur(.5px);
  animation:flicker 2.2s ease-in-out infinite;
}
@keyframes flicker{
  0%,100%{transform:scale(1) translateY(0)}
  30%{transform:scale(1.06,1.14) translateY(-1px)}
  60%{transform:scale(.94,.96)}
}
.wick{width:2px;height:8px;background:#caa;margin:0 auto}
.candle-body{width:8px;height:44px;margin:0 auto;background:linear-gradient(#F2E5DC,#D9C6BC);border-radius:3px}
@keyframes rise{
  from{opacity:0;transform:translateY(24px)}
  to{opacity:1;transform:translateY(0)}
}
.scroll-hint{
  position:absolute;bottom:2.2rem;font-size:.68rem;letter-spacing:.35em;
  text-transform:uppercase;color:rgba(247,239,233,.45);
  opacity:0;animation:rise 1.2s 2s ease forwards;
}

/* ── section shell ─────────────────────────── */
section{position:relative;z-index:2;padding:6rem 1.5rem;max-width:1060px;margin:0 auto}
.section-title{
  font-family:'Cormorant Garamond',serif;font-style:italic;font-weight:500;
  font-size:clamp(2rem,5vw,3rem);text-align:center;margin-bottom:.6rem;
}
.section-sub{
  text-align:center;color:var(--champagne);font-size:.72rem;
  letter-spacing:.4em;text-transform:uppercase;margin-bottom:3.5rem;
}
.rule{
  width:64px;height:1px;background:linear-gradient(90deg,transparent,var(--champagne),transparent);
  margin:0 auto 3rem;
}

/* ── gallery ───────────────────────────────── */
.gallery{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));
  gap:2.4rem;
}
.frame{
  background:var(--ivory);padding:14px 14px 0;cursor:pointer;
  box-shadow:0 18px 40px -18px var(--shadow);
  transition:transform .45s cubic-bezier(.2,.8,.2,1), box-shadow .45s;
  border-radius:2px;
}
.frame:nth-child(odd){transform:rotate(-1.4deg)}
.frame:nth-child(even){transform:rotate(1.2deg)}
.frame:hover,.frame:focus-visible{transform:rotate(0) translateY(-8px);box-shadow:0 28px 50px -18px var(--shadow);outline:none}
.frame:focus-visible{box-shadow:0 0 0 3px var(--blush),0 28px 50px -18px var(--shadow)}
.photo{
  aspect-ratio:4/5;width:100%;object-fit:cover;display:block;background:#E6D5CB;
}
.photo-empty{
  aspect-ratio:4/5;display:flex;flex-direction:column;gap:.6rem;
  align-items:center;justify-content:center;background:linear-gradient(160deg,#EFDFD6,#E2CCC0);
  color:#8A6A5E;font-size:.8rem;letter-spacing:.08em;text-align:center;padding:1rem;
}
.photo-empty svg{width:26px;height:26px;stroke:#8A6A5E}
.caption{
  font-family:'Cormorant Garamond',serif;font-style:italic;
  color:#4A3A34;text-align:center;padding:.85rem .4rem 1rem;font-size:1.05rem;
}
.gallery-note{
  text-align:center;margin-top:2.6rem;font-size:.78rem;
  color:rgba(247,239,233,.5);letter-spacing:.05em;
}

/* ── the letter ────────────────────────────── */
.letter-stage{display:flex;justify-content:center;padding-bottom:2rem}
.envelope{
  position:relative;width:min(340px,86vw);aspect-ratio:4/3;cursor:pointer;
  background:linear-gradient(160deg,#F2E7DE,#E7D6C9);
  border-radius:6px;border:0;
  box-shadow:0 24px 60px -20px var(--shadow);
  transition:transform .4s ease;
}
.envelope:hover,.envelope:focus-visible{transform:translateY(-6px);outline:none}
.envelope:focus-visible{box-shadow:0 0 0 3px var(--blush),0 24px 60px -20px var(--shadow)}
.envelope::before{ /* flap */
  content:"";position:absolute;inset:0 0 auto 0;height:55%;
  background:linear-gradient(170deg,#EADACD,#DCC7B7);
  clip-path:polygon(0 0,100% 0,50% 100%);
  border-radius:6px 6px 0 0;
}
.seal{
  position:absolute;left:50%;top:52%;transform:translate(-50%,-50%);
  width:64px;height:64px;border-radius:50%;
  background:radial-gradient(circle at 35% 30%, #A6394F, #6E1D30 70%);
  display:flex;align-items:center;justify-content:center;
  font-family:'Cormorant Garamond',serif;font-size:1.5rem;color:#F2D8DC;
  box-shadow:inset 0 2px 6px rgba(255,255,255,.25), inset 0 -3px 6px rgba(0,0,0,.35), 0 6px 14px rgba(0,0,0,.3);
  transition:transform .5s ease,opacity .5s ease;
}
.envelope .hint{
  position:absolute;bottom:-2.4rem;left:0;right:0;text-align:center;
  font-size:.68rem;letter-spacing:.35em;text-transform:uppercase;
  color:rgba(247,239,233,.5);
}
.envelope.opening .seal{transform:translate(-50%,-50%) scale(1.4);opacity:0}
.letter{
  display:none;max-width:620px;margin:0 auto;
  background:var(--ivory);color:#3C2B26;border-radius:4px;
  padding:clamp(2rem,6vw,3.5rem);
  box-shadow:0 30px 70px -24px var(--shadow);
  opacity:0;transform:translateY(30px);
}
.letter.open{display:block;animation:unfold 1.1s .1s ease forwards}
@keyframes unfold{to{opacity:1;transform:translateY(0)}}
.letter .salutation{
  font-family:'Cormorant Garamond',serif;font-style:italic;
  font-size:1.7rem;margin-bottom:1.4rem;color:#5C2333;
}
.letter .body{
  font-size:1.02rem;line-height:1.85;white-space:pre-line;
}
.letter .sign{
  margin-top:2.2rem;font-family:'Cormorant Garamond',serif;font-style:italic;
  font-size:1.4rem;text-align:right;color:#5C2333;
}
footer{
  text-align:center;padding:3rem 1rem 4rem;position:relative;z-index:2;
  font-family:'Cormorant Garamond',serif;font-style:italic;
  color:rgba(247,239,233,.55);font-size:1.05rem;
}
</style>
</head>
<body>

<!-- HERO -->
<header class="hero">
  <div class="eyebrow">On your special day</div>
  <h1>Happy Birthday,<span class="name" id="her-name">AlmaAliyah</span></h1>
  <p id="hero-line">Today the world gets to celebrate the person I get to love every day.</p>
  <div class="candle" aria-hidden="true">
    <div class="flame"></div><div class="wick"></div><div class="candle-body"></div>
  </div>
  <div class="scroll-hint">scroll for something made for you</div>
</header>

<!-- MEMORIES -->
<section id="memories">
  <h2 class="section-title">Our little museum</h2>
  <div class="section-sub">moments I never want to forget</div>
  <div class="rule"></div>
  <div class="gallery" id="gallery"></div>
</section>

<!-- LETTER -->
<section id="letter-section">
  <h2 class="section-title">A letter, sealed for you</h2>
  <div class="section-sub">break the seal</div>
  <div class="rule"></div>
  <div class="letter-stage">
    <button class="envelope" id="envelope" aria-label="Open the sealed letter">
      <span class="seal" id="seal">♥</span>
      <span class="hint">tap to open</span>
    </button>
  </div>
  <div class="letter" id="letter" aria-live="polite">
    <div class="salutation" id="letter-salutation"></div>
    <div class="body" id="letter-body"></div>
    <div class="sign" id="letter-sign"></div>
  </div>
</section>

<footer id="footer-line">made with all my heart</footer>

<input type="file" id="file-input" accept="image/*" hidden>

<script>
/* ═══════════════════════════════════════════════════════
   ✏️  CONFIG — everything you'd want to personalize
   ═══════════════════════════════════════════════════════ */
const CONFIG = {
  herName: "AlmaAliyah",

  heroLine: "Today the world gets to celebrate the person I get to love every day.",

  photos: [                       // caption for each frame; src is the embedded photo
    { caption: "Where it all began", src: "data:image/jpeg;base64," },
    { caption: "That trip we still talk about", src: "data:image/jpeg;base64," },
    { caption: "Your favorite kind of evening", src: "data:image/jpeg;base64," },
    { caption: "Just us, being us", src: "data:image/jpeg;base64," },
  ],

  letter: {
    salutation: "My baby,",
    body: `Happy birthday to the most wonderful person I know.

Every year with you feels like a gift I somehow get to keep opening. Thank you for your laugh, your love, your patience, and the way you make ordinary days feel like something worth remembering.

I hope this year brings you everything you deserve — and I plan on being right beside you for all of it.`,
    sign: "— Yours always, Olawale Ajibade"
  },

  footer: "made with all my heart"
};
/* ═══════════════ end of config ═══════════════ */

// apply config
document.getElementById('her-name').textContent = CONFIG.herName;
document.getElementById('hero-line').textContent = CONFIG.heroLine;
document.getElementById('letter-salutation').textContent = CONFIG.letter.salutation;
document.getElementById('letter-body').textContent = CONFIG.letter.body;
document.getElementById('letter-sign').textContent = CONFIG.letter.sign;
document.getElementById('footer-line').textContent = CONFIG.footer;
document.title = "Happy Birthday, " + CONFIG.herName;

// gallery
const gallery = document.getElementById('gallery');
const fileInput = document.getElementById('file-input');
let activeFrame = null;

CONFIG.photos.forEach(p => {
  const f = document.createElement('div');
  f.className = 'frame';
  const media = p.src
    ? `<img class="photo" src="${p.src}" alt="${p.caption}">`
    : `<div class="photo-empty">
        <svg fill="none" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        <span>add a photo</span>
      </div>`;
  f.innerHTML = media + `<div class="caption">${p.caption}</div>`;
  if (!p.src) {
    f.tabIndex = 0;
    f.setAttribute('role','button');
    f.setAttribute('aria-label','Add a photo: ' + p.caption);
    const pick = () => { activeFrame = f; fileInput.click(); };
    f.addEventListener('click', pick);
    f.addEventListener('keydown', e => { if(e.key==='Enter'||e.key===' '){e.preventDefault();pick();} });
  }
  gallery.appendChild(f);
});

fileInput.addEventListener('change', () => {
  const file = fileInput.files[0];
  if (!file || !activeFrame) return;
  const reader = new FileReader();
  reader.onload = e => {
    const img = document.createElement('img');
    img.className = 'photo';
    img.alt = activeFrame.querySelector('.caption').textContent;
    img.src = e.target.result;
    activeFrame.querySelector('.photo-empty, .photo').replaceWith(img);
  };
  reader.readAsDataURL(file);
  fileInput.value = '';
});

// envelope reveal
const envelope = document.getElementById('envelope');
const letter = document.getElementById('letter');
envelope.addEventListener('click', () => {
  envelope.classList.add('opening');
  setTimeout(() => {
    envelope.parentElement.style.display = 'none';
    letter.classList.add('open');
    letter.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }, 550);
});

// petals
const petalChars = ['❀','✿','❁'];
const petalCount = matchMedia('(prefers-reduced-motion: reduce)').matches ? 0 : 16;
for (let i = 0; i < petalCount; i++) {
  const s = document.createElement('span');
  s.className = 'petal';
  s.textContent = petalChars[i % petalChars.length];
  s.style.left = Math.random() * 100 + 'vw';
  s.style.fontSize = (10 + Math.random() * 12) + 'px';
  s.style.animationDuration = (9 + Math.random() * 10) + 's';
  s.style.animationDelay = (-Math.random() * 12) + 's';
  document.body.appendChild(s);
}
</script>
</body>
</html>